      }
    },
    {
      "id": "excel-renderer",
      "name": "Excel 表格渲染",
      "version": "1.0.0",
      "description": "将 Excel 文件流响应渲染为可视化表格。支持 .xlsx 和 .xls 格式，多 Sheet 切换，适用于 API 返回 Excel 下载流的调试场景。",
      "author": "ProtoForge 官方",
      "type": "response-renderer",
      "icon": "📊",
      "entrypoint": "index.js",
      "protocolIds": [],
      "tags": ["Excel", "渲染", "表格", "XLSX"],
      "downloadUrl": "https://raw.githubusercontent.com/chenqi92/protoforge-plugins/main/dist/excel-renderer.tar.gz",
      "contributes": {
        "responseRenderers": [
          {
            "contentTypes": [
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
              "application/vnd.ms-excel",
              "application/octet-stream"
            ],
            "name": "Excel",
            "icon": "📊"
          }
        ]
      },
      "i18n": {
        "en": {
          "name": "Excel Table Renderer",
          "description": "Render Excel file stream responses as visual tables. Supports .xlsx and .xls formats with multi-sheet switching, ideal for debugging APIs that return Excel downloads."
        }
      }
