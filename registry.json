      "author": "ProtoForge 官方",
      "type": "protocol-parser",
      "icon": "🔬",
      "entrypoint": "index.js",
      "protocolIds": ["hj212"],
      "tags": ["环保", "协议", "HJ212", "HJ212-2017", "HJ212-2005", "国标", "CRC16"],
      "downloadUrl": "https://raw.githubusercontent.com/chenqi92/protoforge-plugins/main/dist/hj212-parser.tar.gz",
      "contributes": {
        "parsers": [{ "protocolId": "hj212", "name": "HJ212 协议" }]
      }
    },
    {
